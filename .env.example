# Copy this file to .env and fill in your values
# .env is gitignored — never commit real tokens

HF_TOKEN=
WANDB_API_KEY=
GITHUB_TOKEN=

# Optional: override checkpoint dir (e.g. Google Drive path in Colab)
# CHECKPOINT_DIR=/content/drive/MyDrive/AIMO/checkpoints

# Cache tokenized datasets to Drive so re-tokenization is skipped on restart
# HF_DATASETS_CACHE=/content/drive/MyDrive/AIMO/hf_cache
